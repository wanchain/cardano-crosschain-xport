{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "paths": {
      "@msg-agent/*": ["../msg-agent/src/*"],
      "@msg-agent-test/*": ["../msg-agent/test/*"]
    }
  },
  "include": ["relay/**/*.ts", "test/**/*.ts", "helpers/**/*.ts"]
}
