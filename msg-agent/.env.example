# Blockfrost endpoint: set BLOCKFROST_URL for local devnet (e.g. http://localhost:8080/api/v1)
# or BLOCKFROST_API_KEY for the hosted Blockfrost service. BLOCKFROST_URL takes precedence.
BLOCKFROST_URL=
BLOCKFROST_API_KEY=
ACCOUNT_SEED1=
ACCOUNT_SEED2=
ACCOUNT_SEED3=

# Network: 0=testnet, 1=mainnet
NETWORK=0

# Addresses (defaults to preprod testnet)
GROUP_NFT_HOLDER=addr_test1wpm9vmfxjk0lcrcwzfx76zmcyxpfluux9cwppyu9639thycpks2wj
EVM_CONTRACT_ADDRESS=0xd6Ed4F1F50Cae0c5c7F514F3D0B1220c4a78F71d
RECEIVER_ON_ADA=addr_test1qpm0q3dmc0cq4ea75dum0dgpz4x5jsdf6jk0we04yktpuxnk7pzmhslsptnmagmek76sz92df9q6n49v7ajl2fvkrcdq9semsd
RECEIVER_ON_EVM=0x1d1e18e1a484d0a10623661546ba97DEfAB7a7AE
CROSS_TRANSFER_AMOUNT=100

# Chain IDs
EVM_CHAIN_ID=2153201998
ADA_CHAIN_ID=2147485463

# --- Preprod testnet testing ---
# Set LOCAL_INBOUND_TOKEN to use a test always-true V2 minting policy
# (bypasses MPC signature verification for the inbound check token).
# LOCAL_INBOUND_TOKEN=49480100002221200101
# LOCAL_INBOUND_TOKEN_VERSION=V2
# For local Yaci DevKit, also set YACI_ADMIN_URL=http://localhost:10000
# Generate wallet keys: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Fund wallets via faucet: https://docs.cardano.org/cardano-testnets/tools/faucet/
# See scripts/setup-preprod.ts for automated setup.
